local Remote = game:GetService("ReplicatedStorage"):WaitForChild("__Net"):WaitForChild("MainRemote")
local Toggles = {}

local function Auto(Tab, Name, Args)
    Toggles[Name] = false
    Tab:CreateToggle({
        Name = Name,
        CurrentValue = false,
        Callback = function(v)
            Toggles[Name] = v
            task.spawn(function()
                while Toggles[Name] do
                    Remote:FireServer(unpack(Args))
                    task.wait(0.1)
                end
            end)
        end
    })
end

local AutoWheat = false
Main:CreateToggle({
    Name = "Auto Wheat",
    CurrentValue = false,
    Callback = function(Value)
        AutoWheat = Value
        task.spawn(function()
            while AutoWheat do
                local Farm = workspace:FindFirstChild("__GAME_CONTENT") and workspace.__GAME_CONTENT:FindFirstChild("Farm")
                if Farm then
                    for _, v in pairs(Farm:GetDescendants()) do
                        if v:IsA("ClickDetector") then
                            fireclickdetector(v)
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end
})

